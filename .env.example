# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Auth
NEXTAUTH_SECRET=change-me-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# Staff Login (required for /staff/* routes)
STAFF_PASSWORD=change-me-to-a-secure-password
STAFF_ALLOWED_EMAILS=admin@example.com,staff@example.com

# Local file storage (no S3/AWS needed)
LOCAL_UPLOAD_DIR=./uploads

# AI — set at least GROQ_API_KEY (free at console.groq.com)
GROQ_API_KEY=          # Groq: OCR fallback + chatbot + eligibility smart mock (FREE)
OPENAI_API_KEY=        # Optional: GPT-4o Vision OCR (better accuracy, paid)

# Eligibility
ELIGIBILITY_PROVIDER=groq_langchain   # groq_langchain | change_healthcare | mock
CHANGE_HEALTHCARE_BASE_URL=https://sandbox.apigw.changehealthcare.com
CHANGE_HEALTHCARE_API_KEY=
CLINIC_NPI=

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
