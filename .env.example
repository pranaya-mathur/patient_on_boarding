# Database
DATABASE_URL="postgresql://user:password@localhost:5432/patient_onboarding"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-next-auth-secret-at-least-32-chars"

# Staff Auth
STAFF_PASSWORD="hardcoded-staff-password-for-mvp"
STAFF_ALLOWED_EMAILS="admin@example.com,staff@example.com"

# Storage (S3 Compatible)
STORAGE_BUCKET="patient-docs"
STORAGE_ENDPOINT="https://s3.amazonaws.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"

# Cron
CRON_SECRET="your-cron-secret"
