// MVP schema — patient onboarding, insurance, eligibility, comms, check-in, staff audit.
// Run `npx prisma migrate dev` (or `db push`) after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Patient & visit ----------------------------------------------------------

enum IntakeStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum LegalSex {
  F
  M
  X
  U
}

enum PreferredLanguage {
  en
  es
  other
}

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Patient {
  id          String @id @default(cuid())
  intakeToken String @unique /// Magic link token (opaque, URL-safe)

  intakeStatus IntakeStatus @default(NOT_STARTED)

  legalFirstName  String
  legalLastName   String
  preferredName   String?
  dateOfBirth     DateTime? @db.Date
  legalSex        LegalSex?

  mobilePhone String
  email       String

  addressLine1 String
  addressLine2 String?
  city         String
  state        String @db.VarChar(2)
  zipCode      String

  preferredLanguage PreferredLanguage @default(en)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment         Appointment?
  insurancePolicies   InsurancePolicy[]
  communicationLogs   CommunicationLog[]
  consents            Consent[]
  checkIns            CheckIn[]
}

model Appointment {
  id        String  @id @default(cuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  scheduledAt         DateTime
  locationDescription String?
  providerName        String?
  visitSummary          String? /// Short reason / visit type label for staff UI

  status AppointmentStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIns CheckIn[]
}

// --- Insurance ----------------------------------------------------------------

enum SubscriberRelationship {
  SELF
  SPOUSE
  CHILD
  OTHER
}

model InsurancePolicy {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(true)

  payerKey          String /// e.g. demo_east — maps to configured payer list
  payerDisplayName  String?
  memberId          String
  groupNumber       String?
  subscriberName    String?
  relationship      SubscriberRelationship @default(SELF)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insuranceCards      InsuranceCard[]
  eligibilityChecks   EligibilityCheck[]

  @@index([patientId])
  @@index([patientId, isPrimary])
}

enum InsuranceCardSide {
  FRONT
  BACK
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model InsuranceCard {
  id       String          @id @default(cuid())
  policyId String
  policy   InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  side       InsuranceCardSide
  storageKey String /// S3-compatible object key
  mimeType   String

  ocrStatus       OcrStatus @default(PENDING)
  ocrProviderKey  String? /// e.g. "mock" — swap for real vendor id
  ocrResponse     Json? /// Raw provider / mock OCR output for replay & support
  ocrErrorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([policyId, side])
  @@index([policyId])
  @@index([ocrStatus])
}

// --- Eligibility --------------------------------------------------------------

enum EligibilityStatus {
  NOT_RUN
  PENDING
  VERIFIED
  NEEDS_REVIEW
  FAILED
}

model EligibilityCheck {
  id       String          @id @default(cuid())
  policyId String
  policy   InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  status EligibilityStatus @default(NOT_RUN)

  /// Adapter id: "mock_eligibility" | future clearinghouse slug
  providerKey String

  /// Outbound request snapshot (member id, payer, etc.) for audits & retries
  requestPayload Json?

  /// Inbound normalized + raw payer response — supports mock + real integrations
  responsePayload Json?

  /// One-line summary for queues (e.g. "Active PPO — $25 copay (mock)")
  summaryLine String? @db.Text

  completedAt DateTime?

  /// Manual review path (staff-facing)
  reviewNote            String?   @db.Text
  reviewedAt            DateTime?
  reviewedByStaffUserId String?
  reviewedBy            StaffUser? @relation("EligibilityReviewedBy", fields: [reviewedByStaffUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId, createdAt(sort: Desc)])
  @@index([status])
}

// --- Communications -----------------------------------------------------------

enum CommunicationChannel {
  SMS
  EMAIL
}

enum CommunicationStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

model CommunicationLog {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  channel CommunicationChannel
  status  CommunicationStatus  @default(SCHEDULED)

  templateKey String /// e.g. visit_reminder, intake_nudge

  scheduledFor DateTime?
  sentAt       DateTime?

  errorMessage String? @db.Text
  metadata     Json? /// Provider message ids, retry counts, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([status, scheduledFor])
}

// --- Check-in -----------------------------------------------------------------

enum CheckInMethod {
  QR
  LINK
  STAFF
}

model CheckIn {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  method      CheckInMethod @default(LINK)
  checkedInAt DateTime    @default(now())

  /// Optional: token used when method is LINK/QR (for forensics)
  sourceToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, appointmentId])
  @@index([appointmentId])
}

// --- Consents -----------------------------------------------------------------

model Consent {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  consentKey String /// e.g. HIPAA_NPP, TREATMENT, FINANCIAL_POLICY
  version    String /// Policy document version string

  accepted   Boolean  @default(false)
  acceptedAt DateTime?

  /// Optional integrity / audit fingerprint of presented copy
  contentFingerprint String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, consentKey, version])
  @@index([patientId])
}

// --- Staff & audit ------------------------------------------------------------

model StaffUser {
  id    String @id @default(cuid())
  email String @unique
  name  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]

  eligibilityReviews EligibilityCheck[] @relation("EligibilityReviewedBy")
}

/// Append-only log for staff (and optional system) actions — pair with domain `updatedAt` for full traceability.
enum AuditAction {
  PATIENT_VIEWED
  PATIENT_INTAKE_UPDATED
  PATIENT_INTAKE_STATUS_CHANGED
  INSURANCE_POLICY_UPDATED
  INSURANCE_CARD_UPLOADED
  OCR_RETRIGGERED
  ELIGIBILITY_CHECK_REQUESTED
  ELIGIBILITY_STATUS_CHANGED
  ELIGIBILITY_REVIEW_NOTE_ADDED
  COMMUNICATION_SCHEDULED
  COMMUNICATION_RESENT
  CHECK_IN_RECORDED
  CONSENT_RECORDED
  OTHER
}

model AuditLog {
  id String @id @default(cuid())

  /// Null when action is system-generated (cron, webhook) if you add a system user later
  staffUserId String?
  staffUser   StaffUser? @relation(fields: [staffUserId], references: [id], onDelete: SetNull)

  action     AuditAction
  entityType String /// Prisma model name or stable slug: Patient, EligibilityCheck, …
  entityId   String

  /// Free-form JSON: { from, to } for status changes, note text, IP, user-agent, etc.
  metadata Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([staffUserId, createdAt])
}
